# Copy to .env (same dir as docker-compose.yml) and fill in real values.
# .env is gitignored — never commit the filled file.

# --- Domain ---------------------------------------------------------------
# Must have an A/AAAA record pointing at this server. Caddy provisions TLS
# for it automatically once ports 80/443 are reachable.
DOMAIN=learn.example.com

# --- Postgres -------------------------------------------------------------
# The db service and the app's DATABASE_URL are both built from these.
# Use a strong, URL-safe password (avoid @ : / # ? in the value).
POSTGRES_USER=app
POSTGRES_PASSWORD=REPLACE_WITH_STRONG_PASSWORD
POSTGRES_DB=self_learning

# --- App security (required in production) --------------------------------
# Encrypts the API keys (set on the in-app Settings page) at rest. The app
# refuses to boot without it. Generate once and keep it stable (rotating it
# makes existing encrypted settings unreadable):
#   python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
ENCRYPTION_KEY=REPLACE_WITH_GENERATED_FERNET_KEY

# Exact public origin(s) as a JSON list. Single-origin deploy = just the
# domain above. A "*" wildcard makes the app refuse to boot in production.
CORS_ORIGINS=["https://learn.example.com"]

# --- LLM / embedding keys (optional) --------------------------------------
# This is a single-user app: just open it after deploy and set your keys on
# the in-app Settings page. Filling them here is optional — it pre-seeds the
# defaults so the app works before you visit Settings (resolve_chat /
# resolve_embedding in user_llm.py). Leave blank to configure in-app only.
CHAT_BASE_URL=https://api.deepseek.com
CHAT_API_KEY=
CHAT_MODEL=deepseek-chat
CHAT_PROVIDER=openai
EMBEDDING_API_KEY=
EMBEDDING_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
EMBEDDING_MODEL=text-embedding-v4
