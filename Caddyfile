# Caddy auto-provisions a Let's Encrypt cert for $DOMAIN and redirects
# HTTP -> HTTPS. `reverse_proxy` transparently upgrades WebSocket
# connections, so the future /api/chat/voice/ws endpoint needs no change.
# The single app origin serves the student app at / and the API at /api.

# Redirect the www subdomain to the bare domain so there's one canonical
# origin (keeps CORS_ORIGINS single-valued). Needs a www DNS record too.
www.{$DOMAIN} {
	redir https://{$DOMAIN}{uri} permanent
}

{$DOMAIN} {
	encode gzip

	header {
		Strict-Transport-Security "max-age=31536000; includeSubDomains"
		X-Content-Type-Options "nosniff"
		X-Frame-Options "DENY"
	}

	reverse_proxy app:8000
}
