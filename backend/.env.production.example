# Production environment template. Copy to `.env` ON THE SERVER ONLY,
# fill real values, and never commit the filled file (.env is gitignored).
# Do NOT reuse any key/value from the development .env.

# Hides the FastAPI /docs, /redoc, /openapi.json routes and requires
# ENCRYPTION_KEY. Required in production.
PRODUCTION=true

# Encrypts the api_settings blob (third-party API keys) at rest.
# Required when PRODUCTION=true — the app refuses to boot without it.
# Generate once and keep it stable (rotating it makes existing encrypted
# settings unreadable):
#   python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
ENCRYPTION_KEY=REPLACE_WITH_GENERATED_FERNET_KEY

# Async SQLAlchemy URL. Use a dedicated DB user with a strong password,
# not the dev app:app credentials.
DATABASE_URL=postgresql+asyncpg://USER:PASSWORD@HOST:5432/self_learning

# Exact frontend origin(s) as a JSON list. NO wildcard — the app refuses
# to boot with "*" when PRODUCTION=true.
CORS_ORIGINS=["https://app.example.com"]

# Optional app-level LLM/embedding defaults. You normally set the keys on
# the in-app Settings page instead, so these are usually left blank. If you
# set them, use freshly rotated keys — never the development ones.
# CHAT_API_KEY=
# CHAT_BASE_URL=https://api.deepseek.com
# CHAT_MODEL=deepseek-chat
# EMBEDDING_API_KEY=
# EMBEDDING_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
# EMBEDDING_MODEL=text-embedding-v4
